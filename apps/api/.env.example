# PostgreSQL runtime URL. In Supabase, use the pooler URL here.
DATABASE_URL="postgresql://postgres.PROJECT-REF:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres"

# Direct PostgreSQL URL for Prisma migrations and admin tasks.
DIRECT_DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.PROJECT-REF.supabase.co:5432/postgres"

JWT_SECRET="replace-with-a-strong-secret"
JWT_EXPIRES_IN="7d"
PORT=4000
APP_ENV="development"
CORS_ORIGIN="http://localhost:3000"
APP_WEB_URL="http://localhost:3000"
RESEND_API_KEY="re_replace_with_your_resend_api_key"
EMAIL_FROM="ATAR <onboarding@resend.dev>"
WEB_PUSH_PUBLIC_KEY=""
WEB_PUSH_PRIVATE_KEY=""
WEB_PUSH_SUBJECT="mailto:soporte@atar.local"

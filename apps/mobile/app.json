{
  "expo": {
    "name": "ATAR",
    "slug": "atar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "atar",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.juansedevvsteam.atar"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#4f46ff",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#F8FAFC"
        }
      ],
      "expo-web-browser",
      "expo-font"
    ],
    "extra": {
      "apiUrl": "http://192.168.2.125:4000/api",
      "router": {},
      "eas": {
        "projectId": "c161bb52-4cf0-46f3-bf3d-aa710f78d332"
      }
    },
    "experiments": {
      "typedRoutes": false
    },
    "owner": "juansedevvs-team"
  }
}
